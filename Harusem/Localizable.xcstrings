          }
        }
      }
    },
    "Combine two tiles with +, −, ×, ÷ to make a new number.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "타일 두 개를 +, −, ×, ÷로 합쳐 새 숫자를 만드세요."

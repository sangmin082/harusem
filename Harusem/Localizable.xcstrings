      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘 퍼즐로"
          }
        }
      }
    },
    "Best so far: %lld": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 가장 가까운 값: %lld"

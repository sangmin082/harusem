{
  "sourceLanguage": "en",
  "strings": {
    "%lld day streak": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld일 연속 플레이"
          }
        }
      }
    },
    "%lld/%lld stars": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "별 %1$lld/%2$lld개"
          }
        }
      }
    },
    "A day finished without all 3 stars costs one heart. Hearts refill every 30 minutes.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "별 3개를 다 못 채우고 끝낸 날은 하트가 1개 줄어요. 하트는 30분마다 충전!"
          }
        }
      }
    },
    "Add": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "더하기"
          }
        }
      }
    },
    "Allow notifications in Settings to enable reminders.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "알림을 켜려면 iOS 설정에서 허용해주세요."
          }
        }
      }
    },
    "Archive": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아카이브"
          }
        }
      }
    },

    "Watch an ad for one more puzzle": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "광고 보고 한 문제 더"
          }
        }
      }
    },
    "Within ±10: 2 stars. Within ±25: 1 star.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오차 ±10 이내는 별 2개, ±25 이내는 별 1개예요."
